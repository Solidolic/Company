{
    "root": true,
    "env": {
        "browser": true,
        "es2020": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended",
        "plugin:react-hooks/recommended"
    ],
    "ignorePatterns": [
        "dist",
        ".eslintrc.json"
    ],
    "parser": "@typescript-eslint/parser",
    "plugins": [
        "react-refresh",
        "react-hooks"
    ],
    "rules": {
        "curly": ["error", "all"],
        "quotes": ["error", "single"],
        "object-curly-spacing": ["error", "always"],
        "@typescript-eslint/no-unused-vars": "warn",
        "max-len": [
            "error",
            {
                "code": 120,
                "tabWidth": 2
            }
        ]
    }
}
